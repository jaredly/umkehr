{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "noEmit": true,
        "paths": {
            "umkehr": ["../src/index.ts"],
            "umkehr/crdt": ["../src/crdt/index.ts"],
            "umkehr/migration": ["../src/migration/index.ts"],
            "umkehr/react": ["../src/react/react.tsx"],
