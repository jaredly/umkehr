{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2023", "DOM"],
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": ".",
		"outDir": "dist"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
