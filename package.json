{
    "name": "umkehr",
    "version": "0.1.0",
    "description": "Typed JSON patch updates with undo/redo history and optional React bindings.",
    "keywords": [
        "history",
        "json",
        "patch",
        "react",
        "redo",
        "typescript",
        "undo"
    ],
    "homepage": "https://github.com/jaredly/umkehr#readme",
    "bugs": {
        "url": "https://github.com/jaredly/umkehr/issues"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaredly/umkehr.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "Readme.md"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        },
        "./crdt": {
            "types": "./dist/src/crdt/index.d.ts",
            "import": "./dist/src/crdt/index.js"
        },
        "./richtext": {
            "types": "./dist/src/richtext/index.d.ts",
            "import": "./dist/src/richtext/index.js"
        },
        "./validation": {
            "types": "./dist/src/validation/index.d.ts",
            "import": "./dist/src/validation/index.js"
        },
        "./migration": {
            "import": "./dist/src/migration/index.js",
            "types": "./dist/src/migration/index.d.ts"
        },
        "./react": {
            "types": "./dist/src/react/react.d.ts",
            "import": "./dist/src/react/react.js"
        },
        "./remix": {
            "types": "./dist/src/remix/index.d.ts",
            "import": "./dist/src/remix/index.js"
        },
        "./react-crdt": {
            "types": "./dist/src/react-crdt/index.d.ts",
            "import": "./dist/src/react-crdt/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "clean": "rm -rf dist",
        "task": "bun scripts/task.ts",
        "build": "npm run clean && tsc -p tsconfig.json",
        "test": "npm run build && vitest run",
        "test:e2e:migration": "cd examples/react-crdt && npm run test:e2e",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "typecheck:examples": "npm run build && tsc -p examples/react/tsconfig.json --noEmit && tsc -p examples/react-crdt/tsconfig.json --noEmit",
        "typecheck:tests": "tsc -p tsconfig.type-tests.json",
        "prepack": "npm run build",
        "pack:check": "npm --cache /tmp/umkehr-npm-cache pack --dry-run"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "fast-deep-equal": "^3.1.3"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.3",
        "@typia/unplugin": "^12.1.1",
        "fast-check": "^4.8.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.49.0",
        "typescript": "^5.9.3",
        "typia": "^12.1.1",
        "vitest": "^4.1.6"
    },
    "peerDependencies": {
        "react": ">=18",
        "remix": ">=3.0.0-beta.0 <4",
        "typia": "^12.1.1"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "remix": {
            "optional": true
        },
        "typia": {
            "optional": true
        }
    }
}
