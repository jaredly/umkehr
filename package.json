{
    "name": "umkehr",
    "version": "0.0.0",
    "description": "Typed JSON patch updates with undo/redo history and optional React bindings.",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaredly/umkehr.git"
    },
    "bugs": {
        "url": "https://github.com/jaredly/umkehr/issues"
    },
    "homepage": "https://github.com/jaredly/umkehr#readme",
    "keywords": [
        "json",
        "patch",
        "undo",
        "redo",
        "history",
        "react",
        "typescript"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js"
        },
        "./history": {
            "types": "./dist/history/history.d.ts",
            "import": "./dist/history/history.js"
        },
        "./react": {
            "types": "./dist/react/react.d.ts",
            "import": "./dist/react/react.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "Readme.md",
        "tsconfig.json"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "devDependencies": {
        "@types/react": "^19.2.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "fast-deep-equal": "^3.1.3"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    }
}
